# Required: fine-grained GitHub token limited to approved repositories.
GITHUB_TOKEN=your_fine_grained_github_token

# Required: API key configured in the GPT Action authentication settings.
API_KEY=replace_with_a_long_random_secret

# GitHub account that owns the approved repositories.
GITHUB_OWNER=raliegh2

# Render normally assigns PORT automatically.
PORT=3000

# Temporary workspace and preview settings.
WORKSPACE_ROOT=/tmp/raliegh-ai-workspaces
WORKSPACE_TTL_MINUTES=60
PREVIEW_TTL_MINUTES=30
MAX_FILE_BYTES=1000000
MAX_OUTPUT_BYTES=200000

# Required in production. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PREVIEW_AUTH_SECRET=replace_with_a_second_long_random_secret

# Public URL of the deployed bridge, without a trailing slash.
# Example: https://raliegh-ai-control-center.onrender.com
PUBLIC_BASE_URL=https://your-bridge-service.onrender.com
